{
  "name": "blindpass",
  "private": true,
  "license": "SEE LICENSE IN LICENSES.md",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:skill": "bash scripts/build_bundle.sh",
    "install:skill": "bash scripts/install_skill.sh",
    "publish:dist": "bash scripts/publish_dist.sh",
    "publish:clawhub": "bash scripts/publish_clawhub.sh",
    "dev": "npm run dev --workspaces --if-present",
    "dev:e2e": "node scripts/dev-e2e.mjs",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=packages/dashboard",
    "test:integration": "npm run test:integration --workspace=packages/sps-server",
    "test:e2e:full": "docker compose -f docker-compose.test.yml up -d --wait && npm run test:e2e",
    "test:integration:docker": "bash scripts/test-integration-with-redis.sh",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down --remove-orphans",
    "demo:e2e": "npm run build && node scripts/demo-e2e.mjs",
    "e2e:human": "npm run build && node scripts/e2e-human.mjs",
    "e2e:telegram": "npm run build && node scripts/e2e-openclaw-telegram.mjs"
  },
  "dependencies": {
    "hpke-js": "^1.7.0"
  }
}
