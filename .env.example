# BlindPass local development and self-hosting example environment.
# Copy to `.env` for local source runs, or use these values as a baseline for your
# deployment platform's secret and environment-variable manager.

# -----------------------------------------------------------------------------
# Shared runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3100
SPS_HOST=0.0.0.0
SPS_BASE_URL=http://127.0.0.1:3100
SPS_UI_BASE_URL=http://127.0.0.1:5175
SPS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5175
SPS_TRUST_PROXY=false
SPS_HOSTED_MODE=1
SPS_USE_IN_MEMORY=0
SPS_BODY_LIMIT=1048576

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://blindpass:localdev@127.0.0.1:5433/blindpass
DB_POOL_SIZE=10
REDIS_URL=redis://127.0.0.1:6380

# -----------------------------------------------------------------------------
# Required secrets
# -----------------------------------------------------------------------------
# Replace these before any non-local deployment.
SPS_HMAC_SECRET=replace-with-a-long-random-value
SPS_USER_JWT_SECRET=replace-with-a-long-random-value
SPS_AGENT_JWT_SECRET=replace-with-a-long-random-value

# -----------------------------------------------------------------------------
# Auth, cookies, and abuse protection
# -----------------------------------------------------------------------------
SPS_AUTH_REGISTRATION_LIMIT=10
SPS_AUTH_LOGIN_LIMIT=20
SPS_AUTH_FORGOT_PASSWORD_LIMIT=3
SPS_AUTH_RETRIGGER_VERIFICATION_LIMIT=3
SPS_AUTH_RETRIGGER_VERIFICATION_PER_USER_LIMIT=3
SPS_AUTH_MIN_RESET_RESPONSE_MS=300
SPS_AGENT_TOKEN_RATE_LIMIT=20
SPS_AUTH_MAX_ACTIVE_SESSIONS=10
SPS_AUTH_COOKIE_DOMAIN=
SPS_TURNSTILE_SECRET=
VITE_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Hosted policy bootstrap defaults
# -----------------------------------------------------------------------------
# Keep these empty in multi-tenant hosted mode once per-workspace policies are
# managed through the dashboard. They remain useful for self-hosted bootstrap.
SPS_SECRET_REGISTRY_JSON=
SPS_EXCHANGE_POLICY_JSON=

# Optional self-hosted workload identity providers.
# Hosted/local plugin deployments typically use agent API keys instead.
SPS_AGENT_AUTH_PROVIDERS_JSON=

# -----------------------------------------------------------------------------
# Quotas
# -----------------------------------------------------------------------------
SPS_MEMBER_LIMIT_FREE=2
SPS_MEMBER_LIMIT_STANDARD=10
SPS_AGENT_LIMIT_FREE=2
SPS_AGENT_LIMIT_STANDARD=50
SPS_SECRET_LIMIT_FREE=10
SPS_SECRET_LIMIT_STANDARD=1000
SPS_EXCHANGE_LIMIT_FREE=5
SPS_EXCHANGE_LIMIT_STANDARD=1000

# -----------------------------------------------------------------------------
# Audit and logging
# -----------------------------------------------------------------------------
SPS_AUDIT_RETENTION_DAYS=30
SPS_AUDIT_CLEANUP_INTERVAL_MS=86400000
SPS_LOG_AUDIT_EVENTS=0
SPS_LOG_VERIFICATION_URLS=0
SPS_LOG_PASSWORD_RESET_URLS=0

# -----------------------------------------------------------------------------
# Transactional email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
SPS_EMAIL_FROM=
SPS_EMAIL_REPLY_TO=

# -----------------------------------------------------------------------------
# Billing and payments
# -----------------------------------------------------------------------------
SPS_BILLING_MOCK=1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SPS_STRIPE_STANDARD_PRICE_ID=
BILLING_PORTAL_RETURN_URL=http://127.0.0.1:5173/billing

SPS_X402_ENABLED=1
SPS_X402_PRICE_USD_CENTS=5
SPS_X402_FREE_EXCHANGE_MONTHLY_CAP=10
SPS_X402_FACILITATOR_URL=http://127.0.0.1:3101
SPS_X402_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000001
SPS_X402_NETWORK_ID=eip155:84532
SPS_X402_QUOTE_TTL_SECONDS=300
SPS_X402_LEASE_DURATION_SECONDS=60
SPS_X402_PROVIDER_TIMEOUT_MS=10000

# Local payer configuration for agent-runtime x402 tests.
BLINDPASS_X402_PRIVATE_KEY=
BLINDPASS_X402_RPC_URL=
BLINDPASS_X402_NETWORK_ID=eip155:84532
BLINDPASS_X402_BUDGET_CENTS=25

# -----------------------------------------------------------------------------
# Frontend build-time configuration
# -----------------------------------------------------------------------------
VITE_SPS_API_URL=http://127.0.0.1:3100

# -----------------------------------------------------------------------------
# Agent / plugin runtime configuration
# -----------------------------------------------------------------------------
BLINDPASS_API_KEY=
SPS_AGENT_API_KEY=
BLINDPASS_AGENT_ID=blindpass-agent
