# -----------------------------------------------------------------------------
# SPS SERVER - TESTING ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to .env.test and adjust if necessary.
# These values are tuned for the local Docker testing infrastructure.

NODE_ENV=test

# --- Network & Identity ---
SPS_HOST=0.0.0.0
PORT=3100
SPS_UI_BASE_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# Default points to the container exposed on 5433
DATABASE_URL=postgresql://kryptos:localdev@127.0.0.1:5433/agent_kryptos
DB_POOL_SIZE=10

# --- Cache & Store (Redis) ---
# Note: Docker Compose maps 6380 (host) -> 6379 (container)
REDIS_URL=redis://127.0.0.1:6380
SPS_USE_IN_MEMORY=0

# --- Security Secrets ---
# Use 'openssl rand -base64 32' to generate secure values
SPS_HMAC_SECRET=local-dev-hmac-secret-change-me-in-prod
SPS_USER_JWT_SECRET=local-dev-user-jwt-secret-change-me-in-prod

# --- Rate Limiting (Relaxed for Testing) ---
SPS_AUTH_REGISTRATION_LIMIT=100
SPS_AUTH_LOGIN_LIMIT=100

# --- Audit & Retention ---
SPS_AUDIT_RETENTION_DAYS=7
SPS_AUDIT_CLEANUP_INTERVAL_MS=3600000

# --- Feature Flags & Policy ---
SPS_TRUST_PROXY=true
SPS_BODY_LIMIT=1048576

# --- External Services (Optional for Basic Testing) ---
# Set these if you want to test the full billing and exchange lifecycle.
STRIPE_SECRET_KEY=sk_test_dummy_key_for_setup_only
STRIPE_WEBHOOK_SECRET=whsec_dummy_webhook_secret
SPS_STRIPE_STANDARD_PRICE_ID=price_dummy_standard_tier
# SPS_EXCHANGE_POLICY_JSON='[]'
# SPS_SECRET_REGISTRY_JSON='[]'
