# -----------------------------------------------------------------------------
# SPS SERVER - TESTING ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to .env.test and adjust if necessary.
# These values are tuned for the local Docker testing infrastructure.

NODE_ENV=test

# --- Network & Identity ---
SPS_HOST=0.0.0.0
PORT=3100
SPS_BASE_URL=http://localhost:3100
SPS_DASHBOARD_URL=http://localhost:5173
SPS_UI_BASE_URL=http://localhost:5173
SPS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# --- Database (PostgreSQL) ---
# Default points to the container exposed on 5433
DATABASE_URL="postgresql://blindpass:localdev@localhost:5433/blindpass"
DB_POOL_SIZE=10

# --- Cache & Store (Redis) ---
# Note: Docker Compose maps 6380 (host) -> 6379 (container)
REDIS_URL=redis://127.0.0.1:6380
SPS_USE_IN_MEMORY=0

# --- Security Secrets ---
# Use 'openssl rand -base64 32' to generate secure values
SPS_HMAC_SECRET=local-dev-hmac-secret-change-me-in-prod
SPS_USER_JWT_SECRET=local-dev-user-jwt-secret-change-me-in-prod
SPS_AGENT_JWT_SECRET=local-dev-agent-jwt-secret-change-me-in-prod

# --- Workload Identity & Auth Providers ---
# trusts external workload JWT issuers via jwks_url or jwks_file
# Replaces legacy SPS_GATEWAY_JWKS_URL and SPS_GATEWAY_JWKS_FILE
SPS_AGENT_AUTH_PROVIDERS_JSON='[{"name": "gateway", "issuer": "gateway", "audience": "sps", "jwks_file": "/tmp/jwks.json"}]'

# --- Rate Limiting (Relaxed for Testing) ---
SPS_AUTH_REGISTRATION_LIMIT=1000
SPS_AUTH_LOGIN_LIMIT=1000
SPS_AGENT_TOKEN_RATE_LIMIT=1000
SPS_AUTH_MAX_ACTIVE_SESSIONS=10

# --- Audit & Retention ---
SPS_AUDIT_RETENTION_DAYS=7
SPS_AUDIT_CLEANUP_INTERVAL_MS=3600000

# --- Feature Flags & Policy ---
SPS_TRUST_PROXY=true
SPS_BODY_LIMIT=1048576
SPS_PG_INTEGRATION=1
SPS_HOSTED_MODE=1

# --- Quotas ---
SPS_MEMBER_LIMIT_FREE=2
SPS_MEMBER_LIMIT_STANDARD=10
SPS_AGENT_LIMIT_FREE=2
SPS_AGENT_LIMIT_STANDARD=50
SPS_SECRET_LIMIT_FREE=10
SPS_SECRET_LIMIT_STANDARD=1000
SPS_EXCHANGE_LIMIT_FREE=5
SPS_EXCHANGE_LIMIT_STANDARD=1000

# --- x402 Autonomous Payments ---
SPS_X402_ENABLED=1
SPS_X402_PRICE_USD_CENTS=5
SPS_X402_FREE_EXCHANGE_MONTHLY_CAP=10
SPS_X402_FACILITATOR_URL=http://localhost:3101
SPS_X402_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000001

# --- Exchange & Secrets Registry (JSON Examples) ---
SPS_SECRET_REGISTRY_JSON='[{"secretName": "stripe.api_key.prod", "classification": "finance"}, {"secretName": "restricted.secret", "classification": "sensitive"}]'
SPS_EXCHANGE_POLICY_JSON='[{"ruleId": "allow-test", "secretName": "stripe.api_key.prod", "mode": "allow"}, {"ruleId": "require-human", "secretName": "restricted.secret", "mode": "pending_approval"}]'

# --- External Services (Optional for Basic Testing) ---
# Set these if you want to test the full billing and exchange lifecycle.
STRIPE_SECRET_KEY=sk_test_dummy_key_for_setup_only
STRIPE_WEBHOOK_SECRET=whsec_dummy_webhook_secret
SPS_STRIPE_STANDARD_PRICE_ID=price_dummy_standard_tier
