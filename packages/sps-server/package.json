{
  "name": "@agent-kryptos/sps-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx src/db/migrate.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:db": "SPS_PG_INTEGRATION=1 vitest run tests/db.test.ts",
    "test:integration": "SPS_REDIS_INTEGRATION=1 vitest run tests/redis-integration.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.1",
    "jose": "^6.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
