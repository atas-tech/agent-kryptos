<?xml version="1.0"?>
<Container version="2">
  <Name>BlindPass Postgres</Name>
  <Repository>postgres:16-alpine</Repository>
  <Registry>https://hub.docker.com/_/postgres</Registry>
  <Network>bridge</Network>
  <MyIP />
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/atas-tech/blindpass</Support>
  <Project>https://github.com/atas-tech/blindpass</Project>
  <Overview>Relational database for BlindPass SPS Server (Phase 3E). Stores workspace policies, member accounts, and audit logs.</Overview>
  <Category>Database:SQL</Category>
  <WebUI />
  <TemplateURL>https://raw.githubusercontent.com/atas-tech/blindpass/main/deploy/unraid/blindpass-postgres.xml</TemplateURL>
  <Icon />
  <ExtraParams />
  <PostArgs />
  <CPUset />
  <DateInstalled />
  <DonateText />
  <DonateLink />
  <Requires>Place this container and the SPS container on the same custom Docker network so the SPS server can connect via the container name.</Requires>
  <Config Name="Host Port" Target="5432" Default="5432" Mode="tcp" Description="Postgres host port" Type="Port" Display="always" Required="true" Mask="false">5432</Config>
  <Config Name="POSTGRES_DB" Target="POSTGRES_DB" Default="blindpass" Mode="" Description="Initial database name" Type="Variable" Display="always" Required="true" Mask="false">blindpass</Config>
  <Config Name="POSTGRES_USER" Target="POSTGRES_USER" Default="blindpass" Mode="" Description="Database administrative user" Type="Variable" Display="always" Required="true" Mask="false">blindpass</Config>
  <Config Name="POSTGRES_PASSWORD" Target="POSTGRES_PASSWORD" Default="localdev" Mode="" Description="Database password (Change during deployment!)" Type="Variable" Display="always" Required="true" Mask="true">localdev</Config>
  <Config Name="Data Path" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/blindpass/postgres" Mode="rw" Description="Host path for persistent database storage" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/blindpass/postgres</Config>
</Container>
