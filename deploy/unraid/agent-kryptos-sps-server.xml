<?xml version="1.0"?>
<Container version="2">
  <Name>Agent Kryptos SPS Server</Name>
  <Repository>ghcr.io/tuthan/agent-kryptos-sps-server:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP />
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/tuthan/agent-kryptos</Support>
  <Project>https://github.com/tuthan/agent-kryptos</Project>
  <Overview>Secret Provisioning Service API for Agent Kryptos. Requires Redis and either a JWKS URL or mounted JWKS file.</Overview>
  <Category>Network:Web</Category>
  <WebUI>http://[IP]:[PORT:3100]/healthz</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/tuthan/agent-kryptos/main/deploy/unraid/agent-kryptos-sps-server.xml</TemplateURL>
  <Icon />
  <ExtraParams />
  <PostArgs />
  <CPUset />
  <DateInstalled />
  <DonateText />
  <DonateLink />
  <Requires>Requires Redis on the same custom Docker network. Do not expose Redis directly to the internet.</Requires>
  <Config Name="Host Port" Target="3100" Default="3100" Mode="tcp" Description="SPS API host port" Type="Port" Display="always" Required="true" Mask="false">3100</Config>
  <Config Name="NODE_ENV" Target="NODE_ENV" Default="production" Mode="" Description="Node environment" Type="Variable" Display="always" Required="true" Mask="false">production</Config>
  <Config Name="PORT" Target="PORT" Default="3100" Mode="" Description="Container listen port" Type="Variable" Display="always" Required="true" Mask="false">3100</Config>
  <Config Name="SPS_HOST" Target="SPS_HOST" Default="0.0.0.0" Mode="" Description="Bind address inside the container" Type="Variable" Display="always" Required="true" Mask="false">0.0.0.0</Config>
  <Config Name="REDIS_URL" Target="REDIS_URL" Default="redis://agent-kryptos-redis:6379" Mode="" Description="Redis URL reachable from the same custom Docker network" Type="Variable" Display="always" Required="true" Mask="false">redis://agent-kryptos-redis:6379</Config>
  <Config Name="SPS_HMAC_SECRET" Target="SPS_HMAC_SECRET" Default="" Mode="" Description="Required strong shared HMAC secret" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="SPS_UI_BASE_URL" Target="SPS_UI_BASE_URL" Default="https://secrets.example.com" Mode="" Description="Public browser UI URL used in generated secret links" Type="Variable" Display="always" Required="true" Mask="false">https://secrets.example.com</Config>
  <Config Name="SPS_GATEWAY_JWKS_URL" Target="SPS_GATEWAY_JWKS_URL" Default="" Mode="" Description="Preferred: public JWKS URL for gateway token validation" Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="SPS_GATEWAY_JWKS_FILE" Target="SPS_GATEWAY_JWKS_FILE" Default="/config/jwks.json" Mode="" Description="Optional local JWKS file path inside container. Leave empty if you use SPS_GATEWAY_JWKS_URL." Type="Variable" Display="advanced" Required="false" Mask="false">/config/jwks.json</Config>
  <Config Name="Gateway JWKS File" Target="/config/jwks.json" Default="/mnt/user/appdata/agent-kryptos/jwks.json" Mode="rw" Description="Optional host path for the mounted JWKS file used by SPS_GATEWAY_JWKS_FILE" Type="Path" Display="advanced" Required="false" Mask="false">/mnt/user/appdata/agent-kryptos/jwks.json</Config>
</Container>
