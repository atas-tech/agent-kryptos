<?xml version="1.0"?>
<Container version="2">
  <Name>BlindPass Dashboard</Name>
  <Repository>ghcr.io/tuthan/blindpass-dashboard:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP />
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/tuthan/blindpass</Support>
  <Project>https://github.com/tuthan/blindpass</Project>
  <Overview>Hosted operator dashboard SPA for BlindPass. The SPS API origin is baked into the image at build time via VITE_SPS_API_URL.</Overview>
  <Category>Network:Web</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/tuthan/blindpass/main/deploy/unraid/blindpass-dashboard.xml</TemplateURL>
  <Icon />
  <ExtraParams />
  <PostArgs />
  <CPUset />
  <DateInstalled />
  <DonateText />
  <DonateLink />
  <Requires>The dashboard image must be built with VITE_SPS_API_URL pointing at your public SPS API URL before deployment.</Requires>
  <Config Name="Host Port" Target="8080" Default="8081" Mode="tcp" Description="Dashboard host port" Type="Port" Display="always" Required="true" Mask="false">8081</Config>
</Container>
